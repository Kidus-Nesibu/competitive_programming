n, m = map(int, input().split())
a = list(map(int, input().split()))
b = list(map(int, input().split()))
 
ptr1 = 0
ptr2 = 0
result = []
 
while ptr1 < n and ptr2 < m:
    if a[ptr1] < b[ptr2]:
        result.append(a[ptr1])
        ptr1 += 1
    else:
        result.append(b[ptr2])
        ptr2 += 1
 
result.extend(a[ptr1:])
result.extend(b[ptr2:])
 
print(*result)
